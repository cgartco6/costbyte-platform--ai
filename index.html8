<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CostByte | Enterprise Venture Studio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .hero-mask { mask-image: linear-gradient(to bottom, black 80%, transparent 100%); }
        .enterprise-card { transition: all 0.3s ease; border: 1px solid #e2e8f0; }
        .enterprise-card:hover { transform: translateY(-5px); border-color: #4f46e5; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200 px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-2 font-black text-2xl tracking-tighter italic">
                <i data-lucide="zap" class="text-indigo-600 fill-indigo-600"></i> COSTBYTE
            </div>
            <div class="flex gap-6 text-xs font-bold uppercase tracking-widest">
                <a href="#tiers" class="hover:text-indigo-600">Tiers</a>
                <a href="#compliance" class="hover:text-indigo-600">Compliance</a>
                <a href="owner.html" class="text-slate-400">Admin</a>
            </div>
        </div>
    </nav>

    <header class="bg-white pt-16 pb-32">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
            <div>
                <div class="inline-block px-3 py-1 bg-indigo-100 text-indigo-700 text-[10px] font-black rounded-full mb-6 uppercase">Military Grade Security AES-256</div>
                <h1 class="text-6xl font-black leading-none mb-6">Build Your Venture.<br><span class="text-indigo-600">Free to Start.</span></h1>
                <p class="text-lg text-slate-500 mb-8">Professional venture building with zero ad-spend. We create your assets, viral content, and legal compliance docs automatically.</p>
                <a href="#intake" class="bg-slate-950 text-white px-8 py-4 rounded-xl font-bold hover:bg-indigo-600 transition-all">Get Started Free</a>
            </div>
            <div class="hero-mask">
                <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=800&auto=format&fit=crop" class="rounded-3xl shadow-2xl grayscale hover:grayscale-0 transition-all duration-700" alt="Venture Analytics">
            </div>
        </div>
    </header>

    <section id="tiers" class="max-w-7xl mx-auto px-6 py-24">
        <h2 class="text-3xl font-black text-center mb-16">Select Your Deployment Tier</h2>
        <div class="grid md:grid-cols-4 gap-6">
            <div class="enterprise-card bg-white p-8 rounded-3xl">
                <p class="text-xs font-bold text-slate-400 uppercase">Test Tier</p>
                <h3 class="text-4xl font-black my-4">R0</h3>
                <p class="text-xs text-slate-500 mb-6">Ghost Build. Basic landing page to test your concept.</p>
                <button onclick="deploy('Free', 0)" class="w-full py-3 border-2 border-slate-900 font-bold rounded-xl hover:bg-slate-900 hover:text-white transition-all">Try Free</button>
            </div>
            <div class="enterprise-card bg-white p-8 rounded-3xl">
                <p class="text-xs font-bold text-indigo-600 uppercase">Starter</p>
                <h3 class="text-4xl font-black my-4">R250</h3>
                <p class="text-xs text-slate-500 mb-6">Full Build. Logo + Storefront + Organic Viral Scripts.</p>
                <button onclick="deploy('Bronze', 250)" class="w-full py-3 bg-slate-900 text-white font-bold rounded-xl">Build Now</button>
            </div>
            <div class="enterprise-card bg-white p-8 rounded-3xl border-indigo-500 ring-4 ring-indigo-50">
                <p class="text-xs font-bold text-indigo-600 uppercase">Professional</p>
                <h3 class="text-4xl font-black my-4">R599</h3>
                <p class="text-xs text-slate-500 mb-6">Inventory Sync + 20 AI Video Templates + Compliance Vault.</p>
                <button onclick="deploy('Silver', 599)" class="w-full py-3 bg-indigo-600 text-white font-bold rounded-xl">Scale Up</button>
            </div>
            <div class="enterprise-card bg-slate-950 text-white p-8 rounded-3xl">
                <p class="text-xs font-bold text-indigo-400 uppercase">Empire</p>
                <h3 class="text-4xl font-black my-4">R999</h3>
                <p class="text-xs text-slate-400 mb-6">Autonomous Outreach Node + Global Legal Hardening.</p>
                <button onclick="deploy('Gold', 999)" class="w-full py-3 bg-white text-slate-950 font-bold rounded-xl">Dominate</button>
            </div>
        </div>
    </section>

    <section id="compliance" class="bg-slate-100 py-24">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="text-3xl font-black mb-8">Global Compliance as a Service</h2>
            <div class="grid md:grid-cols-2 gap-8 text-left">
                <div class="bg-white p-6 rounded-2xl">
                    <h4 class="font-bold flex items-center gap-2"><i data-lucide="shield-check" class="text-green-600"></i> SA POPIA Ready</h4>
                    <p class="text-xs text-slate-500 mt-2">Automatic Protection of Personal Information Act documentation generated for your venture.</p>
                </div>
                <div class="bg-white p-6 rounded-2xl">
                    <h4 class="font-bold flex items-center gap-2"><i data-lucide="globe" class="text-blue-600"></i> GDPR Certified</h4>
                    <p class="text-xs text-slate-500 mt-2">Full General Data Protection Regulation compliance for European and global expansion.</p>
                </div>
            </div>
        </div>
    </section>

    <script>
        lucide.createIcons();
        function deploy(tier, price) {
            alert(`Initializing AES-256 Encrypted Build for ${tier} Tier (R${price})`);
            window.location.href = `dashboard.html?tier=${tier}&price=${price}`;
        }
    </script>
</body>
</html>
