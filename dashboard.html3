<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><title>Venture Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 p-6">
    <div id="status-bar" class="max-w-4xl mx-auto mb-6 hidden">
        <div class="bg-orange-100 border-2 border-orange-600 p-4 text-orange-800 text-xs font-bold flex justify-between items-center">
            <span>⚠️ ACCOUNT IN ARREARS: SYSTEM IN SLOW-MODE (No new features. Hosting stays active.)</span>
            <button class="bg-orange-600 text-white px-4 py-1">SETTLE R100</button>
        </div>
    </div>

    <div class="max-w-4xl mx-auto space-y-6">
        <div class="bg-white border-4 border-black p-8 shadow-[12px_12px_0px_#000]">
            <h2 class="text-3xl font-black uppercase italic mb-6">Build Status</h2>
            
            <div id="build-engine" class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-4">
                    <div class="p-4 bg-slate-100 border-2 border-black font-bold">
                        <i data-lucide="cpu" class="inline mr-2"></i> Engine Speed: <span id="speed-text" class="text-green-600">HIGH VELOCITY</span>
                    </div>
                    <div class="p-4 bg-slate-100 border-2 border-black font-bold">
                        <i data-lucide="globe" class="inline mr-2"></i> Visibility: <span class="text-green-600">LIVE & PUBLIC</span>
                    </div>
                </div>
                <div id="upgrade-panel" class="bg-indigo-600 text-white p-6 border-4 border-black">
                    <h4 class="font-black uppercase text-xs mb-4 underline">Active Bonus Pack</h4>
                    <ul class="text-[10px] space-y-2 font-bold">
                        <li>✓ Digital Distribution Handshake</li>
                        <li>✓ Weekly Viral Content Drop</li>
                        <li>✓ Automated Profit Tracking</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
        const urlParams = new URLSearchParams(window.location.search);
        const isArrears = urlParams.get('arrears') === 'true';

        if(isArrears) {
            document.getElementById('status-bar').classList.remove('hidden');
            document.getElementById('speed-text').innerText = "THROTTLED (Slow-Mode)";
            document.getElementById('speed-text').className = "text-orange-600";
            document.getElementById('upgrade-panel').style.opacity = "0.3";
            document.getElementById('upgrade-panel').style.filter = "grayscale(1)";
        }
    </script>
</body>
</html>
