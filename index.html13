<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CostByte HQ | Professional Venture Acceleration</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .service-list li { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #64748b; margin-bottom: 8px; }
        .gradient-text { background: linear-gradient(90deg, #4f46e5, #0ea5e9); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    </style>
</head>
<body class="bg-white text-slate-900">
    <nav class="max-w-7xl mx-auto px-6 py-8 flex justify-between items-center">
        <div class="font-extrabold text-2xl tracking-tighter flex items-center gap-2"><i data-lucide="zap" class="text-indigo-600 fill-current"></i> CostByte</div>
        <div class="flex gap-8 text-[10px] font-bold uppercase tracking-widest text-slate-400">
            <a href="#packages" class="hover:text-black">Packages</a>
            <a href="#cashflow" class="hover:text-black text-orange-600">Instant Cashflow</a>
            <button onclick="toggleAuth()" class="bg-black text-white px-5 py-2 rounded-full">Login</button>
        </div>
    </nav>

    <header class="max-w-5xl mx-auto px-6 pt-20 pb-32 text-center">
        <h1 class="text-6xl md:text-8xl font-extrabold tracking-tighter mb-8">Professional Builds.<br><span class="gradient-text">Aggressive Growth.</span></h1>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto mb-12 font-medium">South Africa's leading autonomous venture studio. From zero-budget starts to aggressive cashflow engines.</p>
        <div class="flex flex-col md:flex-row gap-4 justify-center">
            <a href="#packages" class="bg-indigo-600 text-white px-10 py-5 rounded-2xl font-bold text-lg shadow-xl shadow-indigo-100">Explore Packages</a>
            <a href="#cashflow" class="bg-white border-2 border-slate-100 text-slate-900 px-10 py-5 rounded-2xl font-bold text-lg hover:border-orange-500 hover:text-orange-600 transition-all">Instant Cashflow Engine</a>
        </div>
    </header>

    <section id="packages" class="max-w-7xl mx-auto px-6 py-24 border-t border-slate-50">
        <div class="grid md:grid-cols-4 gap-8">
            <div class="p-8 border border-slate-100 rounded-[2.5rem] bg-slate-50/50">
                <p class="font-bold text-slate-400 uppercase text-[10px] mb-4">Always Free</p>
                <h3 class="text-4xl font-black mb-6">R0</h3>
                <ul class="service-list mb-12">
                    <li><i data-lucide="check" class="text-green-500 w-4"></i> Basic Landing Page</li>
                    <li><i data-lucide="check" class="text-green-500 w-4"></i> SA POPIA Compliance</li>
                    <li><i data-lucide="check" class="text-green-500 w-4"></i> Limited to 200 Users</li>
                </ul>
                <button class="w-full py-4 bg-white border border-slate-200 rounded-xl font-bold">Start Test</button>
            </div>
            <div class="p-8 border border-slate-100 rounded-[2.5rem] bg-white">
                <p class="font-bold text-indigo-600 uppercase text-[10px] mb-4">Starter</p>
                <h3 class="text-4xl font-black mb-6">R250</h3>
                <ul class="service-list mb-12">
                    <li><i data-lucide="check" class="text-green-500 w-4"></i> Full Brand Identity</li>
                    <li><i data-lucide="check" class="text-green-500 w-4"></i> Storefront Deployment</li>
                    <li><i data-lucide="check" class="text-green-500 w-4"></i> Max 500 Subscribers</li>
                </ul>
                <button class="w-full py-4 bg-slate-100 rounded-xl font-bold">Deploy Venture</button>
            </div>
            <div class="p-8 border-2 border-indigo-600 rounded-[2.5rem] bg-indigo-50/20 relative">
                <span class="absolute -top-4 left-8 bg-indigo-600 text-white text-[10px] px-4 py-1 rounded-full font-bold">BEST FOR SCALE</span>
                <p class="font-bold text-indigo-600 uppercase text-[10px] mb-4">Silver Pro</p>
                <h3 class="text-4xl font-black mb-6">R599</h3>
                <ul class="service-list mb-12">
                    <li><i data-lucide="check" class="text-green-500 w-4"></i> Advanced Inventory AI</li>
                    <li><i data-lucide="check" class="text-green-500 w-4"></i> Global GDPR Compliance</li>
                    <li><i data-lucide="check" class="text-green-500 w-4"></i> Max 200 Pro Users</li>
                </ul>
                <button class="w-full py-4 bg-indigo-600 text-white rounded-xl font-bold">Scale Now</button>
            </div>
            <div class="p-8 border border-slate-100 rounded-[2.5rem] bg-slate-950 text-white">
                <p class="font-bold text-indigo-400 uppercase text-[10px] mb-4">Empire</p>
                <h3 class="text-4xl font-black mb-6">R999</h3>
                <ul class="service-list mb-12">
                    <li><i data-lucide="check" class="text-green-400 w-4"></i> Full Autonomous Engine</li>
                    <li><i data-lucide="check" class="text-green-400 w-4"></i> Multi-Currency Support</li>
                    <li><i data-lucide="check" class="text-green-400 w-4"></i> Max 100 Platinum</li>
                </ul>
                <button class="w-full py-4 bg-white text-black rounded-xl font-bold">Go Global</button>
            </div>
        </div>
    </section>

    <section id="cashflow" class="max-w-7xl mx-auto px-6 py-32 bg-orange-50/50 rounded-[4rem] border border-orange-100">
        <div class="max-w-3xl mx-auto text-center">
            <i data-lucide="flame" class="w-16 h-16 text-orange-600 mx-auto mb-6"></i>
            <h2 class="text-5xl font-black tracking-tighter mb-4 italic uppercase">Aggressive Cashflow Engine</h2>
            <p class="text-orange-900 font-bold mb-12 uppercase text-xs tracking-widest">Standalone Upgrade | Not part of standard marketing</p>
            
            <div class="bg-white p-10 rounded-3xl border border-orange-200 text-left shadow-2xl shadow-orange-100">
                <ul class="space-y-6 mb-12">
                    <li class="flex items-start gap-4">
                        <i data-lucide="zap" class="text-orange-600 w-6"></i>
                        <div>
                            <p class="font-black text-sm uppercase">Instant Outreach Node</p>
                            <p class="text-slate-500 text-xs">Direct API targeting for rapid user acquisition.</p>
                        </div>
                    </li>
                    <li class="flex items-start gap-4">
                        <i data-lucide="video" class="text-orange-600 w-6"></i>
                        <div>
                            <p class="font-black text-sm uppercase">Addictive Visual Content</p>
                            <p class="text-slate-500 text-xs">Highly professional, clean, and conversion-optimized ads.</p>
                        </div>
                    </li>
                </ul>
                <div class="flex justify-between items-center pt-8 border-t border-slate-100">
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase">Single Deployment</p>
                        <p class="text-3xl font-black">+ R1,500</p>
                    </div>
                    <button class="bg-orange-600 text-white px-8 py-4 rounded-xl font-bold hover:scale-105 transition-all">ACTIVATE ENGINE</button>
                </div>
            </div>
        </div>
    </section>

    <script>lucide.createIcons();</script>
</body>
</html>
